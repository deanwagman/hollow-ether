{
  "name": "ethernetic",
  "private": true,
  "type": "module",
  "workspaces": [
    "client",
    "server",
    "packages/shared"
  ],
  "scripts": {
    "dev": "npm run db:ensure && concurrently -n client,server -c blue,magenta \"npm run dev -w client\" \"npm run dev -w server\"",
    "db:ensure": "docker compose up -d postgres && wait-on tcp:localhost:5432 -t 60000",
    "db:setup": "npm run db:ensure && npm run prisma:deploy -w server",
    "dev:client": "npm run dev -w client",
    "dev:server": "npm run dev -w server",
    "build": "npm run build -w client",
    "build:shared": "npm run build -w @ethernetic/shared",
    "build:server": "npm run build:shared && npm run prisma:generate -w server && npm run build -w server",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "test:shared": "npm run test -w @ethernetic/shared",
    "test:server": "npm run test -w server",
    "lint": "npm run lint -w client"
  },
  "devDependencies": {
    "@eslint/js": "^9.28.0",
    "eslint": "^9.28.0",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.2.0",
    "concurrently": "^9.1.2",
    "wait-on": "^8.0.3",
    "prettier": "^3.5.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.33.1"
  }
}
